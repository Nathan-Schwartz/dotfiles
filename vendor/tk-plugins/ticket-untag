#!/usr/bin/env bash
# tk-plugin: Remove tags from a ticket
# tk-plugin-version: 1.0.0
set -euo pipefail

if [[ $# -lt 2 ]]; then
    echo "Usage: tk untag <id> <tag> [<tag2> ...]" >&2
    exit 1
fi

if [[ -z "${TICKETS_DIR:-}" || ! -d "$TICKETS_DIR" ]]; then
    echo "Error: TICKETS_DIR not set or does not exist" >&2
    exit 1
fi

# Portable sed -i (BSD vs GNU)
_sed_i() {
    local file="$1"
    shift
    local tmp="${file}.tmp.$$"
    sed "$@" "$file" > "$tmp" && mv "$tmp" "$file"
}

# Resolve ticket file (exact or partial match)
resolve_ticket() {
    local id="$1"
    read -r id <<< "$id"
    local file="$TICKETS_DIR/${id}.md"

    if [[ -f "$file" ]]; then
        echo "$file"
        return 0
    fi

    local matches
    matches=$(find "$TICKETS_DIR" -maxdepth 1 -name "*${id}*.md" 2>/dev/null)
    local count
    count=$(printf '%s\n' "$matches" | grep -c . 2>/dev/null || echo 0)

    if [[ "$count" -eq 1 ]]; then
        echo "$matches"
        return 0
    elif [[ "$count" -gt 1 ]]; then
        echo "Error: ambiguous ID '$id' matches multiple tickets" >&2
        return 1
    else
        echo "Error: ticket '$id' not found" >&2
        return 1
    fi
}

# Extract tags field from YAML frontmatter
get_tags() {
    local file="$1"
    sed -n '/^---$/,/^---$/p' "$file" | grep "^tags:" | sed "s/^tags: *//" || true
}

# Check if a tag exists in a tags string like [a, b, c]
has_tag() {
    local tags_str="$1"
    local tag="$2"
    local clean
    clean=$(echo "$tags_str" | tr -d '[]' | tr ',' '\n' | sed 's/^ *//;s/ *$//')
    echo "$clean" | grep -qx "$tag"
}

id="$1"
shift

file=$(resolve_ticket "$id") || exit 1
ticket_id=$(basename "$file" .md)

for tag in "$@"; do
    current_tags=$(get_tags "$file")

    if [[ -z "$current_tags" || "$current_tags" == "[]" ]]; then
        echo "Error: tag '$tag' not found on $ticket_id (no tags)" >&2
        exit 1
    fi

    if ! has_tag "$current_tags" "$tag"; then
        echo "Error: tag '$tag' not found on $ticket_id" >&2
        exit 1
    fi

    # Remove the tag — handle all positions (only, first, middle, last)
    # Only tag: [tag] -> []
    # First: [tag, b] -> [b]
    # Middle: [a, tag, c] -> [a, c]
    # Last: [a, tag] -> [a]
    _sed_i "$file" "s/^tags: \[$tag\]$/tags: []/"
    _sed_i "$file" "s/^tags: \[$tag, /tags: [/"
    _sed_i "$file" "s/, $tag\]/]/"
    _sed_i "$file" "s/, $tag,/,/"

    echo "Untagged $ticket_id: $tag"
done
