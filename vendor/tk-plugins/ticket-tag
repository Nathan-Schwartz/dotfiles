#!/usr/bin/env bash
# tk-plugin: Add tags to a ticket
# tk-plugin-version: 1.0.0
set -euo pipefail

if [[ $# -lt 2 ]]; then
    echo "Usage: tk tag <id> <tag> [<tag2> ...]" >&2
    exit 1
fi

if [[ -z "${TICKETS_DIR:-}" || ! -d "$TICKETS_DIR" ]]; then
    echo "Error: TICKETS_DIR not set or does not exist" >&2
    exit 1
fi

# Portable sed -i (BSD vs GNU)
_sed_i() {
    local file="$1"
    shift
    local tmp="${file}.tmp.$$"
    sed "$@" "$file" > "$tmp" && mv "$tmp" "$file"
}

# Resolve ticket file (exact or partial match)
resolve_ticket() {
    local id="$1"
    read -r id <<< "$id"
    local file="$TICKETS_DIR/${id}.md"

    if [[ -f "$file" ]]; then
        echo "$file"
        return 0
    fi

    local matches
    matches=$(find "$TICKETS_DIR" -maxdepth 1 -name "*${id}*.md" 2>/dev/null)
    local count
    count=$(printf '%s\n' "$matches" | grep -c . 2>/dev/null || echo 0)

    if [[ "$count" -eq 1 ]]; then
        echo "$matches"
        return 0
    elif [[ "$count" -gt 1 ]]; then
        echo "Error: ambiguous ID '$id' matches multiple tickets" >&2
        return 1
    else
        echo "Error: ticket '$id' not found" >&2
        return 1
    fi
}

# Extract tags field from YAML frontmatter
get_tags() {
    local file="$1"
    sed -n '/^---$/,/^---$/p' "$file" | grep "^tags:" | sed "s/^tags: *//" || true
}

# Check if a tag exists in a tags string like [a, b, c]
has_tag() {
    local tags_str="$1"
    local tag="$2"
    local clean
    clean=$(echo "$tags_str" | tr -d '[]' | tr ',' '\n' | sed 's/^ *//;s/ *$//')
    echo "$clean" | grep -qx "$tag"
}

id="$1"
shift

file=$(resolve_ticket "$id") || exit 1
ticket_id=$(basename "$file" .md)

for tag in "$@"; do
    current_tags=$(get_tags "$file")

    if [[ -z "$current_tags" ]]; then
        # No tags field — insert after first --- (awk for BSD sed portability)
        tmp="${file}.tmp.$$"
        awk -v field="tags: [$tag]" 'NR==1 && /^---$/ {print; print field; next} {print}' "$file" > "$tmp" && mv "$tmp" "$file"
        echo "Tagged $ticket_id: $tag"
    elif [[ "$current_tags" == "[]" ]]; then
        # Empty tags
        _sed_i "$file" "s/^tags: \[\]/tags: [$tag]/"
        echo "Tagged $ticket_id: $tag"
    elif has_tag "$current_tags" "$tag"; then
        echo "Tag already exists: $ticket_id/$tag"
    else
        # Append before closing ]
        _sed_i "$file" "s/^\(tags: .*\)\]/\1, $tag]/"
        echo "Tagged $ticket_id: $tag"
    fi
done
