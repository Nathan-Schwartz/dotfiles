[push]
  default = simple
[merge]
  tool = vimdiff
[difftool]
  trustExitCode = true
[commit]
  verbose = true
[core]
  editor = vim
  excludesfile = ~/.gitignore_global
  ignorecase = false
  # Use delta for syntax-highlighted, side-by-side diffs
  pager = delta
[interactive]
  # Colorize interactive diffs (e.g. git add -p)
  diffFilter = delta --color-only
[delta]
  # Enable n/N keybindings to jump between diff sections
  navigate = true
[alias]
  # Source of conflicts script: https://gist.github.com/jacobvosmaer/3187346
  aliases = !git config --get-regexp 'alias.*' | colrm 1 6 | sed 's/[ ]/ = /' | sort
  ca = commit --amend --allow-empty
  cae = commit --amend --no-edit --no-verify --allow-empty
  co = checkout
  cob = checkout -b
  conflicts = !git diff --name-only --diff-filter=U --relative -z | xargs -0
  d = diff
  exec = "!exec "
  l = log --graph --pretty=format:'%Cred%h%Creset - %Cblue%an%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset' --abbrev-commit --date=relative
  pushhard = push --no-verify -f
  root = "!git rev-parse --show-toplevel"
  git = "!git"
  s = status
  todo = commit --allow-empty --no-verify -m
  wip = !git add -A && git commit
  wtf = "! git log --pretty=tformat:\"%C(auto,yellow)%h%C(auto)%d%C(auto,reset) by %C(auto,blue)%cn%C(auto,reset), %C(auto,cyan)%ar%C(auto,reset)%n %s%n\" --stat"
  cm = commit --no-verify -m
  detail = "!git diff \"$1\"^ \"$1\" #"
[credential]
  helper = store
# Use osxkeychain credential helper on Mac
[include]
  path = ~/.gitconfig.mac
[diff]
  algorithm = patience
  # Let delta highlight moved code blocks in a different color
  colorMoved = default
# Local settings and overrides
[include]
  path = ~/.gitconfig.local
