{
  "env": {
    "SHELL": "/usr/local/bin/bash"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": true,
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(file *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git remote -v)",
      "Bash(tk *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(stat *)"
    ]
  },
  "model": "claude-opus-4-6",
  "effortLevel": "high"
}
